{
  "title": "Pizza App - API Metrics",
  "uid": "pizza-app",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 20,
      "title": "🚨 Active Alerts — Instance > 30 req/min",
      "type": "alertlist",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 5 },
      "options": {
        "alertName": "Instance Request Rate > 30 req/min",
        "dashboardAlerts": false,
        "groupMode": "default",
        "groupBy": ["instance"],
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": false, "error": true },
        "viewMode": "list"
      }
    },
    {
      "id": 21,
      "title": "Requests per Minute per Instance (threshold: 30)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count{application=\"helloservice\", uri=~\"/hello|/PlacePizzaOrder\"}[1m])) * 60",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 1,
      "title": "Overall Request Rate per Endpoint (req/sec)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/hello\"}[1m]))",
          "legendFormat": "GET /hello (all instances)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/PlacePizzaOrder\"}[1m]))",
          "legendFormat": "POST /PlacePizzaOrder (all instances)",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2,
      "title": "Request Rate per Instance - GET /hello",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/hello\"}[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 3,
      "title": "Request Rate per Instance - POST /PlacePizzaOrder",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/PlacePizzaOrder\"}[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 4,
      "title": "Total Requests per Instance (all endpoints)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (increase(http_server_requests_seconds_count{application=\"helloservice\", uri=~\"/hello|/PlacePizzaOrder\"}[30m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 5,
      "title": "Avg Response Time per Instance - GET /hello (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"helloservice\", uri=\"/hello\"}[1m]) / rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/hello\"}[1m]) * 1000",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 6,
      "title": "Avg Response Time per Instance - POST /PlacePizzaOrder (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"helloservice\", uri=\"/PlacePizzaOrder\"}[1m]) / rate(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/PlacePizzaOrder\"}[1m]) * 1000",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 7,
      "title": "HTTP Error Rate per Instance (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, status) (rate(http_server_requests_seconds_count{application=\"helloservice\", status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{instance}} - {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 8,
      "title": "JVM Heap Memory per Instance",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{application=\"helloservice\", area=\"heap\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 9,
      "title": "Load Distribution - /hello Requests by Instance",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (increase(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/hello\"}[30m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 10,
      "title": "Load Distribution - /PlacePizzaOrder Requests by Instance",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (increase(http_server_requests_seconds_count{application=\"helloservice\", uri=\"/PlacePizzaOrder\"}[30m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    }
  ]
}
